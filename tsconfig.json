{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "es2017"],
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"  // <- ADD THIS
  },
  "include": ["app/**/*"]
}
