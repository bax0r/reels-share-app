{
  "compilerOptions": {
    "target": "es6",
    "lib": ["dom", "es2017"],
    "module": "esnext",
    "moduleResolution": "node",        // <- must NOT be node10
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true
  },
  "include": ["app/**/*"]
}
